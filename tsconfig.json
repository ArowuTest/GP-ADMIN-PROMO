{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "moduleResolution": "node",
    "module": "ESNext",
    "target": "ES2017",
    "lib": ["ESNext", "DOM"],
    "skipLibCheck": true,
    "strict": true,
    "types": ["vite/client", "react", "react-dom"]
  },
  "include": ["src"]
}
